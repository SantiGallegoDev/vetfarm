---
interface Props {
  src: string;
  title: string;
  description: string;
  id?: string;
  poster?: string;
}

const { src, title, description, id, poster } = Astro.props;
---

<article
  class="vertical-video-card group relative flex flex-col bg-white rounded-2xl overflow-hidden shadow-md shadow-neutral-200/70 border border-neutral-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1.5"
  data-video-id={id}
>
  <div class="relative aspect-[9/16] bg-neutral-900 overflow-hidden">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      src={src}
      poster={poster}
      preload="metadata"
      playsinline
      controls
      controlslist="nodownload noplaybackrate"
      disablepictureinpicture
    ></video>
    <div class="pointer-events-none absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-black/40 to-transparent"></div>
  </div>
  <div class="p-4 md:p-5">
    <h3 class="font-heading font-semibold text-base md:text-lg text-neutral-800 leading-tight mb-1.5 group-hover:text-primary-600 transition-colors">
      {title}
    </h3>
    <p class="text-sm text-neutral-500 leading-relaxed line-clamp-3">
      {description}
    </p>
  </div>
</article>
