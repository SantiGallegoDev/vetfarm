---
interface Props {
  cols?: 1 | 2 | 3 | 4;
  gap?: 'sm' | 'md' | 'lg';
  class?: string;
  stagger?: boolean;
}

const {
  cols = 3,
  gap = 'md',
  class: className = '',
  stagger = true,
} = Astro.props;

const colClasses = {
  1: 'grid-cols-1',
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
};

const gapClasses = {
  sm: 'gap-4',
  md: 'gap-6 md:gap-8',
  lg: 'gap-8 md:gap-12',
};
---

<div
  class:list={[
    'grid',
    colClasses[cols],
    gapClasses[gap],
    className,
  ]}
  {...stagger && { 'data-animate-stagger': '' }}
>
  <slot />
</div>
