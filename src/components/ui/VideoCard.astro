---
interface Props {
  youtubeId: string;
  title: string;
  description: string;
  provider: string;
}

const { youtubeId, title, description, provider } = Astro.props;
---

<article
  class="video-card group bg-white rounded-2xl shadow-md shadow-neutral-200/60 border border-neutral-100 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1.5"
  data-provider={provider}
>
  <div class="relative w-full aspect-video bg-neutral-100 overflow-hidden">
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1`}
      title={title}
      loading="lazy"
      allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
      referrerpolicy="strict-origin-when-cross-origin"
      class="absolute inset-0 w-full h-full border-0"
    ></iframe>
  </div>
  <div class="p-5 md:p-6">
    <span class="inline-block text-xs font-semibold text-primary-700 bg-primary-50 px-2.5 py-1 rounded-full mb-3">
      {provider}
    </span>
    <h3 class="font-heading font-semibold text-base md:text-lg text-neutral-800 mb-2 group-hover:text-primary-600 transition-colors">
      {title}
    </h3>
    <p class="text-sm text-neutral-500 leading-relaxed">
      {description}
    </p>
  </div>
</article>
