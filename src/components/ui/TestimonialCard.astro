---
interface Props {
  beforeImage: string;
  afterImage: string;
  text: string;
  productUsed: string;
  author?: string;
}

const { beforeImage, afterImage, text, productUsed, author } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-md shadow-neutral-200/50 border border-neutral-100 overflow-hidden transition-all duration-300 hover:shadow-xl group">
  <!-- Before / After Images -->
  <div class="grid grid-cols-2 relative">
    <div class="relative aspect-square bg-neutral-100 overflow-hidden">
      <img
        src={beforeImage}
        alt="Antes del tratamiento"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
      <span class="absolute bottom-2 left-2 bg-neutral-800/80 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded-lg flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Antes
      </span>
    </div>
    <div class="relative aspect-square bg-neutral-100 overflow-hidden">
      <img
        src={afterImage}
        alt="Después del tratamiento"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
      <span class="absolute bottom-2 left-2 bg-green-600/90 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded-lg flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
        </svg>
        Después
      </span>
    </div>
    {/* Arrow divider */}
    <div class="absolute inset-y-0 left-1/2 -translate-x-1/2 flex items-center z-10">
      <div class="w-8 h-8 bg-white rounded-full shadow-lg flex items-center justify-center">
        <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="p-5 md:p-6">
    <div class="mb-3 text-primary-300">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
      </svg>
    </div>
    <p class="text-neutral-600 text-sm leading-relaxed mb-4 italic">{text}</p>
    <div class="flex items-center justify-between border-t border-neutral-100 pt-4">
      <div>
        {author && (
          <p class="text-sm font-bold text-neutral-800">{author}</p>
        )}
        <p class="text-xs text-primary-600 font-medium flex items-center gap-1 mt-0.5">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
          </svg>
          {productUsed}
        </p>
      </div>
      <div class="flex text-amber-400">
        {Array.from({length: 5}).map(() => (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
    </div>
  </div>
</div>
