---
interface Props {
  class?: string;
  hover?: boolean;
  padding?: boolean;
}

const {
  class: className = '',
  hover = true,
  padding = true,
} = Astro.props;
---

<div
  class:list={[
    'bg-white rounded-2xl shadow-sm border border-neutral-100 overflow-hidden',
    hover && 'transition-all duration-300 hover:shadow-md hover:-translate-y-1',
    padding && 'p-6',
    className,
  ]}
>
  <slot />
</div>
