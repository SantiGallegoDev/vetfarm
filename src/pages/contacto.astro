---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ContactForm from '../components/ui/ContactForm.astro';
import Grid from '../components/ui/Grid.astro';

import branches from '../data/branches.json';
---

<MainLayout title="Contacto" description="Contáctanos por WhatsApp, teléfono o email. Estamos listos para atenderte.">

  <Hero
    title="Contacto"
    subtitle="Estamos listos para atenderte. Elige el canal de contacto que prefieras."
    backgroundImage="https://images.unsplash.com/photo-1576201836106-db1758fd1c97?w=1920&q=80&auto=format"
    size="small"
  />

  <Section background="white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Contact Form -->
      <div>
        <h2 class="text-primary-800 text-2xl font-heading font-bold mb-2">Envíanos un mensaje</h2>
        <p class="text-neutral-500 mb-8">Completa el formulario y te contactaremos vía WhatsApp.</p>
        <ContactForm />
      </div>

      <!-- Contact Info -->
      <div>
        <h2 class="text-primary-800 text-2xl font-heading font-bold mb-2">Información de contacto</h2>
        <p class="text-neutral-500 mb-8">También puedes contactarnos directamente por estos medios.</p>

        <div class="space-y-6">
          <!-- WhatsApp -->
          <a
            href="https://wa.me/5210000000000?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20sus%20productos."
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 rounded-xl bg-green-50 hover:bg-green-100 transition-colors group"
          >
            <div class="w-12 h-12 bg-green-600 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-800 group-hover:text-green-700 transition-colors">WhatsApp</p>
              <p class="text-sm text-neutral-500">+52 (10) 0000-0000</p>
            </div>
          </a>

          <!-- Phone -->
          <div class="flex items-center gap-4 p-4 rounded-xl bg-primary-50">
            <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-800">Teléfono</p>
              <p class="text-sm text-neutral-500">(000) 000-0000</p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-center gap-4 p-4 rounded-xl bg-primary-50">
            <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-800">Email</p>
              <p class="text-sm text-neutral-500">contacto@vetfarm.com</p>
            </div>
          </div>

          <!-- Schedule -->
          <div class="flex items-center gap-4 p-4 rounded-xl bg-primary-50">
            <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-800">Horario</p>
              <p class="text-sm text-neutral-500">Lun - Vie: 9:00 - 18:00 | Sáb: 9:00 - 14:00</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Branches -->
  <Section background="gray">
    <SectionHeading
      title="Nuestras sucursales"
      subtitle="Visítanos en cualquiera de nuestras 3 ubicaciones."
    />
    <Grid cols={3}>
      {branches.map((branch) => (
        <div class="bg-white rounded-2xl shadow-sm border border-neutral-100 overflow-hidden p-5">
          <h3 class="font-heading font-semibold text-lg text-neutral-800 mb-3">{branch.name}</h3>
          <div class="space-y-2 text-sm text-neutral-600">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{branch.address}</span>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span>{branch.phone}</span>
            </div>
          </div>
          <a
            href={`https://wa.me/${branch.whatsapp}?text=${encodeURIComponent('Hola, quiero información sobre sus productos.')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full bg-green-600 hover:bg-green-700 text-white text-sm font-semibold py-2.5 rounded-lg transition-colors duration-200 mt-4"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      ))}
    </Grid>
  </Section>

</MainLayout>
