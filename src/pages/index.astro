---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Grid from '../components/ui/Grid.astro';
import CategoryCard from '../components/ui/CategoryCard.astro';
import ProductCard from '../components/ui/ProductCard.astro';
import TestimonialCard from '../components/ui/TestimonialCard.astro';
import BranchCard from '../components/ui/BranchCard.astro';
import Button from '../components/ui/Button.astro';

import categories from '../data/categories.json';
import products from '../data/products.json';
import testimonials from '../data/testimonials.json';
import branches from '../data/branches.json';
import events from '../data/events.json';

const featuredProducts = products.filter((p) => p.featured);
const previewTestimonials = testimonials.slice(0, 3);
const previewBranches = branches.slice(0, 3);

const features = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Calidad certificada',
    desc: 'Productos desarrollados bajo los más altos estándares veterinarios.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
    title: 'Investigación científica',
    desc: 'Fórmulas respaldadas por investigación y evidencia clínica.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    title: 'Bienestar animal',
    desc: 'Comprometidos con la salud de cada paciente veterinario.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
    title: 'Asesoría profesional',
    desc: 'Equipo de veterinarios disponibles para atención personalizada.',
  },
];
---

<MainLayout title="Inicio" description="Vetfarm - Empresa veterinaria con más de 30 años de experiencia. Productos veterinarios de calidad para caninos, felinos y aves.">

  <!-- Hero -->
  <Hero
    title="Salud animal con respaldo científico"
    subtitle="Más de 30 años desarrollando productos veterinarios de calidad para el bienestar de especies menores y mayores. Confían en nosotros miles de profesionales veterinarios en todo México."
    buttonText="Ver productos"
    buttonHref="/productos"
    secondaryButtonText="Contactar por WhatsApp"
    secondaryButtonHref="https://wa.me/5210000000000?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20sus%20productos."
    backgroundImage="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1920&q=80&auto=format"
    size="large"
    badges={['Calidad certificada', 'Envío nacional', 'Asesoría veterinaria']}
  />

  <!-- Features Bar -->
  <section class="relative mt-8 md:mt-12 z-20 pb-8">
    <div class="container-custom">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4" data-animate-stagger>
        {features.map((f) => (
          <div class="bg-white rounded-2xl shadow-lg shadow-neutral-200/50 p-5 md:p-6 flex items-start gap-4 border border-neutral-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 bg-primary-50 rounded-xl flex items-center justify-center shrink-0 text-primary-600">
              <Fragment set:html={f.icon} />
            </div>
            <div>
              <h3 class="font-heading font-semibold text-sm md:text-base text-neutral-800">{f.title}</h3>
              <p class="text-xs md:text-sm text-neutral-500 mt-0.5 leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro + Stats -->
  <Section background="white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div data-animate="slide-left">
        <span class="inline-block text-sm font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full mb-4">Sobre Vetfarm</span>
        <h2 class="text-primary-800 mb-6 text-balance">Líderes en salud animal desde 1995</h2>
        <p class="text-neutral-600 text-lg leading-relaxed mb-4">
          Vetfarm se ha consolidado como una empresa líder en el desarrollo y distribución de productos veterinarios en México. Nuestra misión es ofrecer soluciones de salud animal con los más altos estándares de calidad.
        </p>
        <p class="text-neutral-500 leading-relaxed mb-8">
          Contamos con líneas especializadas para caninos, felinos y aves, respaldadas por investigación científica y la confianza de miles de profesionales veterinarios en todo el país.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="bg-primary-50 rounded-xl p-4 text-center">
            <p class="text-2xl md:text-3xl font-heading font-bold text-primary-600">30+</p>
            <p class="text-xs text-primary-700/70 mt-1 font-medium">Años</p>
          </div>
          <div class="bg-secondary-50 rounded-xl p-4 text-center">
            <p class="text-2xl md:text-3xl font-heading font-bold text-secondary-600">500+</p>
            <p class="text-xs text-secondary-700/70 mt-1 font-medium">Puntos de venta</p>
          </div>
          <div class="bg-green-50 rounded-xl p-4 text-center">
            <p class="text-2xl md:text-3xl font-heading font-bold text-green-600">10+</p>
            <p class="text-xs text-green-700/70 mt-1 font-medium">Productos</p>
          </div>
          <div class="bg-amber-50 rounded-xl p-4 text-center">
            <p class="text-2xl md:text-3xl font-heading font-bold text-amber-600">3</p>
            <p class="text-xs text-amber-700/70 mt-1 font-medium">Sucursales</p>
          </div>
        </div>
      </div>

      <!-- Image collage -->
      <div class="relative" data-animate="slide-right">
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <img
              src="https://images.unsplash.com/photo-1628009368231-7bb7cfcb0def?w=400&q=80&auto=format"
              alt="Veterinario con perro"
              class="rounded-2xl w-full aspect-[3/4] object-cover shadow-lg"
              loading="lazy"
            />
            <img
              src="https://images.unsplash.com/photo-1574158622682-e40e69881006?w=400&q=80&auto=format"
              alt="Gato saludable"
              class="rounded-2xl w-full aspect-square object-cover shadow-lg"
              loading="lazy"
            />
          </div>
          <div class="space-y-4 mt-8">
            <img
              src="https://images.unsplash.com/photo-1612170153139-6f881ff067e0?w=400&q=80&auto=format"
              alt="Aves de producción"
              class="rounded-2xl w-full aspect-square object-cover shadow-lg"
              loading="lazy"
            />
            <img
              src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=400&q=80&auto=format"
              alt="Clínica veterinaria"
              class="rounded-2xl w-full aspect-[3/4] object-cover shadow-lg"
              loading="lazy"
            />
          </div>
        </div>
        <!-- Decorative badge -->
        <div class="absolute -bottom-4 -left-4 bg-primary-600 text-white rounded-2xl p-4 shadow-xl hidden md:flex items-center gap-3">
          <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="font-heading font-bold text-sm">Confianza veterinaria</p>
            <p class="text-xs text-white/70">Desde 1995</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Categories -->
  <section class="section-padding bg-gradient-to-b from-neutral-50 to-white relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100/30 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-secondary-100/20 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>

    <div class="container-custom relative z-10">
      <SectionHeading
        title="Nuestras categorías"
        subtitle="Productos especializados por especie para cubrir las necesidades de cada paciente."
      />
      <Grid cols={3}>
        {categories.map((cat) => (
          <CategoryCard
            name={cat.name}
            image={cat.image}
            href={`/categorias/${cat.slug}`}
            count={products.filter((p) => p.category === cat.id).length}
          />
        ))}
      </Grid>
      <div class="text-center mt-10" data-animate>
        <Button href="/categorias" variant="outline">Ver todas las categorías</Button>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <Section background="white">
    <SectionHeading
      title="Productos destacados"
      subtitle="Los productos más recomendados por profesionales veterinarios."
    />
    <Grid cols={4}>
      {featuredProducts.map((product) => (
        <ProductCard
          name={product.name}
          description={product.description}
          image={product.image}
          category={categories.find((c) => c.id === product.category)?.name || product.category}
          species={product.species}
          presentations={product.presentations}
        />
      ))}
    </Grid>
    <div class="text-center mt-10" data-animate>
      <Button href="/productos" variant="primary" size="lg">Ver catálogo completo</Button>
    </div>
  </Section>

  <!-- Testimonials Preview -->
  <section class="section-padding bg-gradient-to-b from-neutral-50 via-primary-50/30 to-neutral-50 relative overflow-hidden">
    <div class="absolute top-20 left-10 opacity-[0.03]">
      <svg class="w-40 h-40" viewBox="0 0 24 24" fill="currentColor" class="text-primary-900">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
      </svg>
    </div>
    <div class="container-custom relative z-10">
      <SectionHeading
        title="Casos de éxito"
        subtitle="Resultados reales de profesionales veterinarios que confían en nuestros productos."
      />
      <Grid cols={3}>
        {previewTestimonials.map((t) => (
          <TestimonialCard
            beforeImage={t.beforeImage}
            afterImage={t.afterImage}
            text={t.text}
            productUsed={t.productUsed}
            author={t.author}
          />
        ))}
      </Grid>
      <div class="text-center mt-10" data-animate>
        <Button href="/testimonios" variant="outline">Ver más testimonios</Button>
      </div>
    </div>
  </section>

  <!-- Events Preview -->
  <Section background="white">
    <SectionHeading
      title="Eventos recientes"
      subtitle="Vetfarm participa activamente en congresos, exposiciones y capacitaciones del sector veterinario."
    />
    <Grid cols={3}>
      {events.map((event) => (
        <div class="bg-white rounded-2xl shadow-md shadow-neutral-200/60 border border-neutral-100 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1.5 group">
          <div class="relative aspect-video bg-neutral-100 overflow-hidden">
            <img
              src={event.images[0].src}
              alt={event.images[0].alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
            <span class="absolute bottom-3 left-3 text-xs font-semibold text-white bg-primary-600/90 backdrop-blur-sm px-3 py-1 rounded-full">
              {new Date(event.date).toLocaleDateString('es-MX', { year: 'numeric', month: 'short' })}
            </span>
          </div>
          <div class="p-5 md:p-6">
            <h3 class="font-heading font-semibold text-base md:text-lg text-neutral-800 mb-2 group-hover:text-primary-600 transition-colors">{event.title}</h3>
            <p class="text-sm text-neutral-500 leading-relaxed line-clamp-2">{event.description}</p>
            <div class="mt-4 flex items-center text-primary-600 text-sm font-semibold group-hover:gap-2 transition-all">
              <span>Ver galería</span>
              <svg class="w-4 h-4 ml-1 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </Grid>
    <div class="text-center mt-10" data-animate>
      <Button href="/eventos" variant="outline">Ver galería completa</Button>
    </div>
  </Section>

  <!-- Branches Preview -->
  <Section background="gray">
    <SectionHeading
      title="Nuestras sucursales"
      subtitle="Encuéntranos en 3 ubicaciones estratégicas en México."
    />
    <Grid cols={3}>
      {previewBranches.map((branch) => (
        <BranchCard
          name={branch.name}
          address={branch.address}
          phone={branch.phone}
          whatsapp={branch.whatsapp}
          schedule={branch.schedule}
          image={branch.image}
          mapEmbed={branch.mapEmbed}
        />
      ))}
    </Grid>
    <div class="text-center mt-10" data-animate>
      <Button href="/sucursales" variant="outline">Ver todas las sucursales</Button>
    </div>
  </Section>

  <!-- Company History CTA -->
  <section class="section-padding relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1548767797-d8c844163c4c?w=1920&q=80&auto=format"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-900/95 to-primary-800/80"></div>

    <!-- Decorative paw -->
    <div class="absolute right-10 bottom-10 opacity-[0.05]">
      <svg class="w-48 h-48" viewBox="0 0 24 24" fill="white">
        <ellipse cx="7" cy="5" rx="2.5" ry="3"/>
        <ellipse cx="17" cy="5" rx="2.5" ry="3"/>
        <ellipse cx="3.5" cy="11" rx="2.5" ry="3"/>
        <ellipse cx="20.5" cy="11" rx="2.5" ry="3"/>
        <path d="M12 22c-4 0-7-3-7-6.5S8 9 12 9s7 3.5 7 6.5S16 22 12 22z"/>
      </svg>
    </div>

    <div class="container-custom relative z-10">
      <div class="max-w-3xl" data-animate>
        <span class="inline-block text-sm font-semibold text-secondary-400 bg-white/10 backdrop-blur-sm px-3 py-1 rounded-full mb-4">Nuestra historia</span>
        <h2 class="text-white mb-6 text-balance">Más de 30 años transformando la salud animal en México</h2>
        <p class="text-white/85 text-lg leading-relaxed mb-8 max-w-2xl">
          Fundada en 1995, Vetfarm nació con la visión de transformar la salud animal en México. Hoy somos una empresa reconocida por la calidad de nuestros productos y el compromiso con la comunidad veterinaria.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="/empresa" variant="secondary" size="lg">Conoce nuestra historia</Button>
          <Button href="/contacto" variant="outline" class="border-white/30 text-white hover:bg-white/10">Contáctanos</Button>
        </div>
      </div>
    </div>
  </section>

</MainLayout>
