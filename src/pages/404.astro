---
import MainLayout from '../layouts/MainLayout.astro';
import Button from '../components/ui/Button.astro';
---

<MainLayout title="Página no encontrada" description="La página que buscas no existe.">
  <section class="section-padding bg-white">
    <div class="container-custom text-center max-w-xl mx-auto">
      <div class="text-8xl md:text-9xl font-heading font-bold text-primary-100 mb-4">404</div>
      <h1 class="text-2xl md:text-3xl text-primary-800 mb-4">Página no encontrada</h1>
      <p class="text-neutral-500 mb-8 leading-relaxed">
        Lo sentimos, la página que estás buscando no existe o ha sido movida.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/" variant="primary">Ir al inicio</Button>
        <Button href="/empresa" variant="outline">Sobre nosotros</Button>
      </div>
    </div>
  </section>
</MainLayout>
