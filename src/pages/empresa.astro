---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Grid from '../components/ui/Grid.astro';
import Card from '../components/ui/Card.astro';

const values = [
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    title: 'Honestidad',
    description: 'Transparencia en cada proceso.',
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>',
    title: 'Trabajo en equipo',
    description: 'Cada área de Vetfarm trabaja en conjunto para que tu pedido llegue completo, a tiempo y con el respaldo técnico que necesitas.',
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>',
    title: 'Calidez humana',
    description: 'Detrás de cada pedido hay un veterinario o un productor que necesita respuesta rápida. Los atendemos como tal.',
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    title: 'Puntualidad',
    description: 'Tu paciente no puede esperar. Nuestro compromiso con el abastecimiento oportuno no es un slogan: es una operación diaria.',
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>',
    title: 'Buen servicio',
    description: 'Asesoría técnica antes, durante y después de la compra. No solo vendemos productos: acompañamos a nuestros clientes.',
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>',
    title: 'Calidad',
    description: 'Solo trabajamos con marcas de respaldo comprobado. La calidad de cada producto que distribuimos no es negociable.',
  },
];

const timeline = [
  { title: 'Fundación', description: 'Vetfarm nace en Quito, fundada por técnicos especializados en producción y reproducción bovina.' },
  { title: 'Expansión de cobertura', description: 'Ampliamos nuestra cobertura a especies menores: caninos y felinos entran al portafolio farmacéutico.' },
  { title: 'CC El Recreo (Sur)', description: 'Apertura del punto de atención en CC El Recreo para cubrir la demanda de Quito Sur.' },
  { title: 'Plaza Lisboa (El Inca)', description: 'Apertura del punto en Plaza Lisboa (Francisco de Orellana y El Inca) para atender Quito Norte.' },
  { title: 'Nuevas marcas', description: 'Incorporación de laboratorios internacionales reconocidos: VetNova, Vet Gamma y otros.' },
  { title: 'Atención digital', description: 'Implementación de canales digitales y WhatsApp para consulta y pedidos en línea.' },
  { title: 'Consolidación', description: 'Tres sucursales activas en Quito y presencia consolidada en el mercado veterinario nacional.' },
];
---

<MainLayout title="Quiénes somos" description="Vetfarm nació en 1995 fundada por técnicos en producción bovina. Hoy somos el proveedor de confianza del sector veterinario en Ecuador, con 3 sucursales en Quito.">

  <Hero
    title="Tres décadas eligiendo lo mejor para la salud animal"
    subtitle="Fundada por técnicos del sector. Consolidada por la confianza del veterinario ecuatoriano. Esto es Vetfarm."
    backgroundImage="https://images.unsplash.com/photo-1628009368231-7bb7cfcb0def?w=1920&q=80&auto=format"
    size="medium"
  />

  <!-- History -->
  <Section background="white">
    <SectionHeading
      title="De la ganadería a todas las especies"
      subtitle="Cómo un proyecto técnico se convirtió en el referente veterinario de Ecuador."
    />
    <div class="max-w-3xl mx-auto" data-animate>
      <p class="text-neutral-600 text-lg leading-relaxed mb-6">
        Vetfarm nació en 1995 fundada por técnicos con amplia experiencia en producción y reproducción bovina. Desde esa base sólida y especializada, fuimos ampliando nuestra cobertura farmacéutica hacia la mayoría de especies domésticas, respondiendo a la necesidad del sector veterinario ecuatoriano.
      </p>
      <p class="text-neutral-600 leading-relaxed mb-6">
        A lo largo de tres décadas crecimos junto al mercado. Hoy contamos con tres sucursales en Quito, una red de distribución a nivel nacional y un portafolio selecto de las mejores marcas veterinarias internacionales y productos para mejorar el bienestar animal. No fabricamos todo: seleccionamos lo mejor.
      </p>
      <p class="text-neutral-600 leading-relaxed">
        Lo que nos ha mantenido durante 30 años no es la innovación por sí sola. Es la coherencia: el mismo compromiso con el abastecimiento oportuno, los mismos estándares de calidad en cada producto, la misma atención directa al veterinario y al productor que nos eligió desde el primer día.
      </p>
    </div>
  </Section>

  <!-- Timeline -->
  <Section background="gray">
    <SectionHeading
      title="Nuestra trayectoria"
      subtitle="Momentos clave en 30 años de servicio al sector veterinario ecuatoriano."
    />
    <div class="max-w-3xl mx-auto">
      <div class="relative">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-primary-200 -translate-x-1/2"></div>
        {timeline.map((item, index) => (
          <div class:list={[
            'relative flex items-start mb-10 last:mb-0',
            index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse',
          ]}>
            <div class="hidden md:block md:w-1/2" />
            <div class="absolute left-4 md:left-1/2 w-4 h-4 bg-primary-600 rounded-full border-4 border-white shadow -translate-x-1/2 mt-1.5 z-10"></div>
            <div class:list={[
              'ml-10 md:ml-0 md:w-1/2',
              index % 2 === 0 ? 'md:pl-10' : 'md:pr-10',
            ]}>
              <h4 class="font-heading font-semibold text-lg text-neutral-800">{item.title}</h4>
              <p class="text-neutral-500 text-sm mt-1 leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Mission & Vision -->
  <Section background="white">
    <Grid cols={2} gap="lg" stagger={false}>
      <div class="bg-primary-50 rounded-2xl p-8 md:p-10" data-animate="slide-left">
        <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="font-heading font-bold text-2xl text-primary-800 mb-4">Misión</h3>
        <p class="text-neutral-600 leading-relaxed">
          Brindar un servicio de excelencia a nuestros socios comerciales con abastecimiento oportuno de productos farmacéuticos veterinarios de marcas reconocidas internacionalmente. Lo hacemos a través de un equipo especializado en toda la cadena comercial, enfocado en resolver las necesidades reales de cada cliente.
        </p>
      </div>
      <div class="bg-secondary-50 rounded-2xl p-8 md:p-10" data-animate="slide-right">
        <div class="w-12 h-12 bg-secondary-500 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
        </div>
        <h3 class="font-heading font-bold text-2xl text-secondary-700 mb-4">Visión</h3>
        <p class="text-neutral-600 leading-relaxed">
          Ser empresa líder del mercado ecuatoriano en importación y comercialización de productos farmacéuticos veterinarios y productos enfocados a mejorar el bienestar animal, de alta calidad a precios competitivos.
        </p>
      </div>
    </Grid>
  </Section>

  <!-- Values -->
  <Section background="gray">
    <SectionHeading
      title="Lo que nos define"
      subtitle="Los principios que guían cada decisión en Vetfarm desde 1995."
    />
    <Grid cols={3}>
      {values.map((value) => (
        <Card>
          <div class="text-primary-600 mb-4" set:html={value.icon} />
          <h4 class="font-heading font-semibold text-lg text-neutral-800 mb-2">{value.title}</h4>
          <p class="text-sm text-neutral-500 leading-relaxed">{value.description}</p>
        </Card>
      ))}
    </Grid>
  </Section>

  <!-- Team -->
  <Section background="white">
    <SectionHeading
      title="El equipo que está detrás de cada producto"
      subtitle="Veterinarios, técnicos y asesores que conocen a fondo lo que venden. No somos una bodega: somos un equipo especializado."
    />
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-neutral-600 leading-relaxed mb-6">
        El equipo Vetfarm está compuesto por médicos veterinarios, técnicos agropecuarios y especialistas en farmacología animal. Cuando consultas con nosotros, hablas con alguien que entiende tu caso.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-20 h-20 bg-primary-100 rounded-full mx-auto mb-3 flex items-center justify-center">
            <svg class="w-10 h-10 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <p class="text-sm font-semibold text-neutral-700">Veterinarios</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-primary-100 rounded-full mx-auto mb-3 flex items-center justify-center">
            <svg class="w-10 h-10 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <p class="text-sm font-semibold text-neutral-700">Investigadores</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-primary-100 rounded-full mx-auto mb-3 flex items-center justify-center">
            <svg class="w-10 h-10 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <p class="text-sm font-semibold text-neutral-700">Colaboradores</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-primary-100 rounded-full mx-auto mb-3 flex items-center justify-center">
            <svg class="w-10 h-10 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
            </svg>
          </div>
          <p class="text-sm font-semibold text-neutral-700">Sucursales</p>
        </div>
      </div>
    </div>
  </Section>

</MainLayout>
